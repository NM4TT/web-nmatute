---
import Layout from '#layouts/Layout.astro';
---

<Layout title="404 - Not Found">
    <div class="pt-32 pb-64">
        <section class="flex flex-col items-center justify-center space-y-12">
          <h1 class="font-display font-extrabold text-center text-7xl md:text-8xl lg:text-9xl tracking-tighter">
            404
          </h1>
          <div class="text-center space-y-4 max-w-md mx-auto">
            <p class="text-2xl font-bold tracking-tight">Something is missing.</p>
            <p class="opacity-70 text-lg leading-relaxed">
              The page you're looking for doesn't exist or has been moved to another location.
            </p>
          </div>
          <a href="/" class="btn-primary">
            Back to Resume
          </a>
        </section>
    </div>
</Layout>
