---
import Layout from '#layouts/Layout.astro';
import ContactButton from '#components/ui/ContactButton.svelte';
import MobileSection from '#components/ui/MobileSection.svelte';
import SocialMedia from '#components/ui/SocialMedia.svelte';
import Keywords from '#components/cv/Keywords.svelte';
import EducationItem from '#components/cv/EducationItem.svelte';
import WorkExperienceItem from '#components/cv/WorkExperienceItem.svelte';

import { getLocalizedEntry, getUiTranslation } from '../../lib/i18n';
import { formatItemDates } from '#lib/utils';
import { Image } from 'astro:assets';
import MAIN_PIC from '#assets/images/main_pic.jpg';

interface Props {
    lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;
const t = getUiTranslation(lang);

const getSectionItems = async (id: string) => {
    const data = await getLocalizedEntry(lang, id);
    return data?.items || [];
};

const experience = formatItemDates(await getSectionItems('professional-exp'), lang);
const education = formatItemDates(await getSectionItems('education'), lang);
const about = await getLocalizedEntry(lang, 'about');
const skills = (await getSectionItems('tools-skills')).flatMap((item: any) => item.keywords || []);
const languages = (await getSectionItems('languages')).flatMap((item: any) => item.keywords || []);
const socials = await getLocalizedEntry(lang, 'socials') || [];
---

<Layout title={t.resumeTitle} lang={lang}>
    <div id="curriculum" class="pt-10">
        <section id="first" class="mt-10 md:mt-20">
            <div class="flex flex-col md:flex-row items-center justify-center gap-10 md:gap-20 max-w-6xl mx-auto px-4">
                <div class="w-2/3 md:w-2/5">
                    <Image src={MAIN_PIC} 
                        alt="Nicolas Matute" 
                        class="h-auto w-full rounded-2xl shadow-2xl transition-all duration-700" 
                        loading="eager" />
                </div>
                <div class="w-full md:w-3/5 flex flex-col items-center md:items-start text-center md:text-left">
                    <h1 class="font-extrabold mb-2 text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl tracking-tighter">
                        Nicolas Matute
                    </h1>
                    <h2 class="font-mono text-xl sm:text-2xl lg:text-3xl text-secondary mb-6 tracking-widest uppercase font-bold">
                        Software Engineer
                    </h2>
                    <p class="text-lg sm:text-xl mb-8 max-w-lg leading-relaxed opacity-90">
                        {about?.text || (lang === 'es' ? "Construyendo sistemas escalables y experiencias web modernas con un enfoque en arquitectura limpia y excelencia técnica." : "Building scalable systems and modern web experiences with a focus on clean architecture and technical excellence.")}
                    </p>
                    <div class="flex flex-col sm:flex-row items-center gap-6 mb-10">
                        <ContactButton text={t.contactMe} />
                        <ul class="list-none flex items-center gap-4">
                            {socials.map((socialMedia: any) => (
                                <li class="text-2xl">
                                    <SocialMedia data={socialMedia} />
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4">
            <h2 class="font-display text-4xl font-bold mb-8 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                {t.whoIAm}
            </h2>
            <div class="content">
                <p class="text-xl leading-relaxed font-light italic">
                    "{about?.text}"
                </p>
            </div>
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4">
            <h2 class="font-display text-4xl font-bold mb-12 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                {t.workExperience}
            </h2>
            <div class="content">
                {experience.map((item) => (
                    <WorkExperienceItem data={item} />
                ))}
            </div>          
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4">
            <h2 class="font-display text-4xl font-bold mb-12 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                {t.education}
            </h2>
            <div class="content">
                {education.map((item) => (
                    <EducationItem data={item} />
                ))}
            </div>
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4">
            <h2 class="font-display text-4xl font-bold mb-12 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                {t.toolsSkills}
            </h2>
            <div class="content">
                <Keywords data={skills} />
            </div>
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4 pb-32">
            <h2 class="font-display text-4xl font-bold mb-12 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                {t.languages}
            </h2>
            <div class="content">
                <ul class="flex flex-wrap gap-8">
                    {languages.map((item: string) => (
                        <li class="group">
                            <span class="text-2xl font-bold">{item}</span>
                        </li>
                    ))}
                </ul>
            </div>
        </section>
    </div>
</Layout>
