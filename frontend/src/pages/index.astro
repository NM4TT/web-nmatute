---
import Layout from '#layouts/Layout.astro';
import ContactButton from '#components/ui/ContactButton.svelte';
import MobileSection from '#components/ui/MobileSection.svelte';
import SocialMedia from '#components/ui/SocialMedia.svelte';
import Keywords from '#components/cv/Keywords.svelte';
import EducationItem from '#components/cv/EducationItem.svelte';
import WorkExperienceItem from '#components/cv/WorkExperienceItem.svelte';

import { getEntry } from 'astro:content';
import { formatItemDates } from '#lib/utils';
import { SOCIAL_MEDIA_LIST } from '#lib/constants';
import { Image } from 'astro:assets';
import MAIN_PIC from '#assets/images/main_pic.jpg';

const getSectionItems = async (id: string) => {
    const entry = await getEntry('data', id);
    return entry?.data.items || [];
};

const experience = formatItemDates(await getSectionItems('professional-exp'));
const education = formatItemDates(await getSectionItems('education'));
const about = (await getEntry('data', 'about'))?.data;
const skills = (await getSectionItems('tools-skills')).flatMap((item: any) => item.keywords || []);
const languages = (await getSectionItems('languages')).flatMap((item: any) => item.keywords || []);
---

<Layout title="Nicolas Resume">
    <div id="curriculum" class="pt-10">
        <section id="first" class="mt-5">
            <div
                id="desktop-first-look"
                class="hidden md:flex flex-row items-center justify-center gap-20 max-w-6xl mx-auto"
            >
                <div class="w-2/5">
                    <Image src={MAIN_PIC} 
                        alt="Nicolas Matute" class="h-auto w-full rounded-2xl shadow-2xl transition-all duration-700" loading="eager" />
                </div>
                <div class="w-3/5 flex flex-col items-start">
                    <h1 class="font-extrabold mb-2 text-6xl lg:text-7xl xl:text-8xl tracking-tighter">
                        Nicolas Matute
                    </h1>
                    <h2 class="font-mono text-2xl lg:text-3xl text-secondary mb-8 tracking-widest uppercase font-bold">
                        Software Engineer
                    </h2>
                    
                    <p class="text-xl mb-8 max-w-lg leading-relaxed opacity-90">
                        {about?.text || "Building scalable systems and modern web experiences with a focus on clean architecture and technical excellence."}
                    </p>

                    <div class="flex items-center gap-6 mb-10">
                        <ContactButton />
                        <ul class="list-none flex items-center gap-4">
                            {SOCIAL_MEDIA_LIST.map((socialMedia) => (
                                <li class="text-2xl">
                                    <SocialMedia data={socialMedia} />
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>
            </div>
            <MobileSection title="Resume" />
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4">
            <h2 class="font-display text-4xl font-bold mb-8 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                Who I Am
            </h2>
            <div class="content">
                <p class="text-xl leading-relaxed font-light italic">
                    "{about?.text}"
                </p>
            </div>
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4">
            <h2 class="font-display text-4xl font-bold mb-12 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                Work Experience
            </h2>
            <div class="content">
                {experience.map((item) => (
                    <WorkExperienceItem data={item} />
                ))}
            </div>          
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4">
            <h2 class="font-display text-4xl font-bold mb-12 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                Education
            </h2>
            <div class="content">
                {education.map((item) => (
                    <EducationItem data={item} />
                ))}
            </div>
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4">
            <h2 class="font-display text-4xl font-bold mb-12 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                Tools & Skills
            </h2>
            <div class="content">
                <Keywords data={skills} />
            </div>
        </section>

        <section class="cv-section mt-32 flex flex-col max-w-4xl mx-auto px-4 pb-32">
            <h2 class="font-display text-4xl font-bold mb-12 flex items-center gap-4">
                <span class="h-0.5 w-12 bg-secondary/30"></span>
                Languages
            </h2>
            <div class="content">
                <ul class="flex flex-wrap gap-8">
                    {languages.map((item: string) => (
                        <li class="group">
                            <span class="text-sm font-mono text-secondary uppercase tracking-widest block mb-1">Language</span>
                            <span class="text-2xl font-bold">{item}</span>
                        </li>
                    ))}
                </ul>
            </div>
        </section>
    </div>
</Layout>
